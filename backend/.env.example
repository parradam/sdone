# Copy to .env and adjust as needed. All variables use the SDONE_ prefix.

# SQLAlchemy database URL. Defaults to a repo-relative SQLite file.
SDONE_DATABASE_URL=sqlite:///./sdone.db

# Root log level (DEBUG, INFO, WARNING, ERROR).
SDONE_LOG_LEVEL=INFO

# Deployment environment: dev | test | prod.
SDONE_ENV=dev
